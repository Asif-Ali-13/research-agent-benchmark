# Gemini API (get key from https://aistudio.google.com/apikey)

GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# LLM settings
MODEL=gemini/gemini-2.5-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192

# Execution safety
EXECUTION_TIMEOUT_SECONDS=120
MAX_FEEDBACK_ITERATIONS=3

# Task qualification (feedback loop)
FEEDBACK_PASS_THRESHOLD=0.75
QUALIFICATION_PASS_THRESHOLD=0.8
QUALIFICATION_FAIL_ON_METRIC_WORSENED=true
REQUIRE_CLEAN_STDERR=false
USE_LLM_QUALIFICATION=true
QUALIFICATION_IN_BASELINE=false

# LLM rate limits (Gemini free tier ~5 req/min)
LLM_RETRY_MAX_ATTEMPTS=4
BENCHMARK_TASK_DELAY_SECONDS=12

# API server
API_HOST=0.0.0.0
API_PORT=8000

# SQLite experiment tracking
DATABASE_URL=sqlite:///experiments/results/experiments.db

# Logging
LOG_LEVEL=INFO
